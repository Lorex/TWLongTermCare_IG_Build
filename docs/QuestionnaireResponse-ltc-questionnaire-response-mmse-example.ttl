     fhir:text [ fhir:v "這裡有一個圖形,請在旁邊畫出一個相同的圖形。(兩五邊形,交一四邊形,有兩交點,則給分)" ] ;
     fhir:answer ( [
       fhir:value [
         a fhir:Integer ;
         fhir:v 1
       ]
     ] )
  ] ) . # 

