  fhir:differential [
     fhir:element ( [
       fhir:id [ fhir:v "Location" ] ;
       fhir:path [ fhir:v "Location" ] ;
       fhir:short [ fhir:v "個案位置監測的資訊" ]
     ] [
       fhir:id [ fhir:v "Location.status" ] ;
       fhir:path [ fhir:v "Location.status" ] ;
       fhir:short [ fhir:v "位置記錄的狀態" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "active"
       ]
     ] [
       fhir:id [ fhir:v "Location.name" ] ;
       fhir:path [ fhir:v "Location.name" ] ;
       fhir:short [ fhir:v "個案所在的地點名稱" ] ;
       fhir:definition [ fhir:v "個案所在的地點名稱，例如：日照中心、家裡、公園等" ]
     ] [
       fhir:id [ fhir:v "Location.description" ] ;
       fhir:path [ fhir:v "Location.description" ] ;
       fhir:short [ fhir:v "位置描述" ] ;
       fhir:definition [ fhir:v "位置的詳細描述資訊" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Location.mode" ] ;
       fhir:path [ fhir:v "Location.mode" ] ;
       fhir:short [ fhir:v "位置模式" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "instance"
       ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Location.type" ] ;
       fhir:path [ fhir:v "Location.type" ] ;
       fhir:short [ fhir:v "位置類型" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Location.type.coding" ] ;
       fhir:path [ fhir:v "Location.type.coding" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Location.type.coding.system" ] ;
       fhir:path [ fhir:v "Location.type.coding.system" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:Uri ;
         fhir:v "http://terminology.hl7.org/CodeSystem/v3-RoleCode"^^xsd:anyURI ;
         fhir:l <http://terminology.hl7.org/CodeSystem/v3-RoleCode>
       ]
     ] [
       fhir:id [ fhir:v "Location.type.coding.code" ] ;
       fhir:path [ fhir:v "Location.type.coding.code" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "PTRES"
       ]
     ] [
       fhir:id [ fhir:v "Location.type.coding.display" ] ;
       fhir:path [ fhir:v "Location.type.coding.display" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "Patient's Residence"
       ]
     ] [
       fhir:id [ fhir:v "Location.telecom" ] ;
       fhir:path [ fhir:v "Location.telecom" ] ;
       fhir:short [ fhir:v "位置相關的聯絡方式" ]
     ] [
       fhir:id [ fhir:v "Location.address" ] ;
       fhir:path [ fhir:v "Location.address" ] ;
       fhir:short [ fhir:v "位置的地址資訊" ]
     ] [
       fhir:id [ fhir:v "Location.address.text" ] ;
       fhir:path [ fhir:v "Location.address.text" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Location.position" ] ;
       fhir:path [ fhir:v "Location.position" ] ;
       fhir:short [ fhir:v "位置的經緯度座標" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Location.position.longitude" ] ;
       fhir:path [ fhir:v "Location.position.longitude" ] ;
       fhir:short [ fhir:v "經度座標" ] ;
       fhir:definition [ fhir:v "GPS 經度座標，以十進位度數格式表示" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
