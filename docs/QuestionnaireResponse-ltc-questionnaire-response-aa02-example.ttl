  ] ; # 
  fhir:item ( [
     fhir:linkId [ fhir:v "serviceAdaptation" ] ;
     fhir:text [ fhir:v "追蹤服務適應與介入情形" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "contactTime" ] ;
       fhir:text [ fhir:v "聯繫時間" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:DateTime ;
           fhir:v "2024-04-05T10:00:00+08:00"^^xsd:dateTime
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "contactTarget" ] ;
       fhir:text [ fhir:v "電訪對象" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "個案"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "女兒（主要照顧者）"
         ]
       ] )
     ] )
  ] [
     fhir:linkId [ fhir:v "approvedServices" ] ;
     fhir:text [ fhir:v "核定服務類別及頻率（填入最新一筆計劃核定碼別及各碼別適應情形）" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "homeServicePlan" ] ;
       fhir:text [ fhir:v "居家服務（應填寫碼別與服務單位）" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "BA01×31；每週3次，每次120分鐘，輪派單位○○社區居服"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "transportationPlan" ] ;
       fhir:text [ fhir:v "交通服務（金額/頻率/使用規劃）" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "每月1,840元，預計每三個月回診2趟"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "professionalServicePlan" ] ;
       fhir:text [ fhir:v "專業服務（代碼/目標/對象/時間）" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "CA07×1；目標：提升移位能力；對象：個案及居服員；時間：每週一次共四週"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "respitePlan" ] ;
       fhir:text [ fhir:v "喘息服務" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "GA09×42，區間4/01–4/30，單位：○○喘息服務中心"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "assistiveDevicesPlan" ] ;
       fhir:text [ fhir:v "輔具服務（購置/租賃/品項）" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "EA01-2便盆椅、EA01-3沐浴椅"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "otherReferralPlan" ] ;
       fhir:text [ fhir:v "其他轉介資源、服務（無論有無轉介皆須說明）" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "轉介家庭照顧者支持服務，安排喘息與照顧技巧課程"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "closeCaseNote" ] ;
       fhir:text [ fhir:v "複評後無失能欲結案，已提供相對應之資源訊息" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "無"
         ]
       ] )
     ] )
  ] [
     fhir:linkId [ fhir:v "serviceUsageTracking" ] ;
