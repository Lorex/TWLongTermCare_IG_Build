         ] )
       ] [
         fhir:linkId [ fhir:v "assistiveDevicesStatus" ] ;
         fhir:text [ fhir:v "輔具服務" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "已購買便盆椅與沐浴椅，無其他問題"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "referralProgress" ] ;
         fhir:text [ fhir:v "轉介家照服務資源" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "4/03 轉介○○社工，4/06 完成連結並安排4/20 家訪"
           ]
         ] )
       ] )
     ] )
  ] [
     fhir:linkId [ fhir:v "planSuitabilityChange" ] ;
     fhir:text [ fhir:v "整體計畫的適切性及需求異動" ] ;
     fhir:answer ( [
       fhir:value [
         a fhir:String ;
         fhir:v "符合，家屬配合度高，無異動"
       ]
     ] )
  ] [
     fhir:linkId [ fhir:v "otherHandling" ] ;
     fhir:text [ fhir:v "其他處理事項（服務諮詢、申訴處理）" ] ;
     fhir:answer ( [
       fhir:value [
         a fhir:String ;
         fhir:v "無"
       ]
     ] )
  ] ) . # 

