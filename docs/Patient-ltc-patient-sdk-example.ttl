     fhir:system [ fhir:v "phone" ] ;
     fhir:value [ fhir:v "0912345678" ]
  ] ) ; # 
  fhir:gender [ fhir:v "male"] ; # 
  fhir:birthDate [ fhir:v "1950-01-01"^^xsd:date] ; # 
