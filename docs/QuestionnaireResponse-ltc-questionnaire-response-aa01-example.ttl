ierarchy\">轉介其他服務資源</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"/><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">轉介至社區關懷據點，參與健康促進活動，維持社會參與。</td></tr>#xD;\n<tr style=\"border: 1px #F0F0F0 solid; padding:0px; vertical-align: top; background-color: #F7F7F7\"><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; white-space: nowrap; background-image: url(tbl_bck00.png)\" class=\"hierarchy\"><img src=\"tbl_spacer.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"tbl_vjoin_end.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"icon-q-string.png\" alt=\".\" style=\"background-color: #F7F7F7; background-color: inherit\" title=\"Item\" class=\"hierarchy\"/> otherNotes</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">其他備註</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"/><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">個案家屬配合度高，建議定期追蹤服務品質，如有需要可調整服務內容。</td></tr>#xD;\n<tr><td colspan=\"4\" class=\"hierarchy\"><br/><a href=\"https://hl7.org/fhir/R4/formats.html#table\" title=\"Legend for this format\"><img src=\"data:image/png;base64,\" alt=\"doco\" style=\"background-color: inherit\"/> Documentation for this format</a></td></tr></table></div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:questionnaire [
     fhir:v "http://ltc-ig.fhir.tw/Questionnaire/questionnaire-aa01-example"^^xsd:anyURI ;
     fhir:l <http://ltc-ig.fhir.tw/Questionnaire/questionnaire-aa01-example>
  ] ; # 
  fhir:status [ fhir:v "completed"] ; # 
  fhir:subject [
     fhir:l <http://ltc-ig.fhir.tw/Patient/ltc-patient-chen-ming-hui> ;
     fhir:reference [ fhir:v "Patient/ltc-patient-chen-ming-hui" ]
  ] ; # 
  fhir:authored [ fhir:v "2024-01-15T10:30:00+08:00"^^xsd:dateTime] ; # 
  fhir:author [
     fhir:l <http://ltc-ig.fhir.tw/PractitionerRole/ltc-practitioner-role-nurse-example> ;
     fhir:reference [ fhir:v "PractitionerRole/ltc-practitioner-role-nurse-example" ]
  ] ; # 
  fhir:item ( [
     fhir:linkId [ fhir:v "planTarget" ] ;
     fhir:text [ fhir:v "計畫目標" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "phoneContactDate" ] ;
       fhir:text [ fhir:v "電聯日期" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:DateTime ;
           fhir:v "2024-01-10T14:00:00+08:00"^^xsd:dateTime
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "homeVisitDate" ] ;
       fhir:text [ fhir:v "家訪日期" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:DateTime ;
           fhir:v "2024-01-15T09:00:00+08:00"^^xsd:dateTime
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "coVisitors" ] ;
       fhir:text [ fhir:v "偕同訪視者" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "陳明輝(個案本人)"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "陳美玲(女兒，主要照顧者)"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "caseOverview" ] ;
       fhir:text [ fhir:v "個案概況" ] ;
       fhir:item ( [
         fhir:linkId [ fhir:v "physicalMentalCondition" ] ;
         fhir:text [ fhir:v "身心概況" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "個案意識清楚，因中風導致左側偏癱，身障等級為中度，目前定期至復健科就診，服用抗凝血藥物。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "economicIncome" ] ;
         fhir:text [ fhir:v "經濟收入" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "領有身障津貼每月4,872元，女兒提供生活費，無其他收入來源。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "livingEnvironment" ] ;
         fhir:text [ fhir:v "居住環境" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "與女兒同住於3樓公寓，環境整潔，已安裝扶手及防滑墊，使用助行器輔助行走。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "socialSupport" ] ;
         fhir:text [ fhir:v "社會支持" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "女兒為主要照顧者，支持度高，鄰里關係良好，已申請居家服務，無高風險因子。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "other" ] ;
         fhir:text [ fhir:v "其他" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "退休前為公務員，生活規律，重視家庭關係。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "reassessmentValue" ] ;
         fhir:text [ fhir:v "複評評值" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "個案狀況穩定，各項服務執行良好，目標達成率達80%以上。"
           ]
         ] )
       ] )
     ] [
       fhir:linkId [ fhir:v "careGoals" ] ;
       fhir:text [ fhir:v "照顧目標" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "1. 維持基本日常生活功能 2. 提升行動能力 3. 預防跌倒 4. 維持社會參與"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "discrepancyExplanation" ] ;
       fhir:text [ fhir:v "與照專建議服務項目、問題清單不一致原因說明及未來規劃、後續追蹤計劃等" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "經與案家討論，目前暫無備餐之意願，改為代購服務。個案身體狀況穩定，同意接受專業服務。"
         ]
       ] )
     ] )
  ] [
     fhir:linkId [ fhir:v "executionPlan" ] ;
     fhir:text [ fhir:v "計畫執行規劃" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "approvedServices" ] ;
       fhir:text [ fhir:v "長照服務核定項目、頻率" ] ;
       fhir:item ( [
         fhir:linkId [ fhir:v "bCodeServices" ] ;
         fhir:text [ fhir:v "B碼(輪派/指定○○○單位)" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "BA13[陪同外出]*32: 每週3次,一次2個單位(3*2*4.5=27),陪同個案推助步車到公園散步及購置晚餐。每月5次,搭配陪同就醫使用。共計27+5=32(單位/月)"
           ]
         ] [
           fhir:value [
             a fhir:String ;
             fhir:v "BA14[陪同就醫]*5: 每週1次,陪同個案至XX醫院XX科及XX科回診。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "cCodeServices" ] ;
         fhir:text [ fhir:v "C碼:(輪派/指定○○○單位)" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "CA01[身體照顧服務]: 協助個案進行日常生活活動，包括個人衛生、穿衣等，提升生活品質。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "dCodeServices" ] ;
         fhir:text [ fhir:v "D碼" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "DA01[居家復健]: 每週2次，協助個案進行肢體復健訓練，提升左側肢體功能。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "eFCodeServices" ] ;
         fhir:text [ fhir:v "E.F碼" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "EA01[輔具服務]: 提供助行器維護及調整服務，確保使用安全。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "gCodeServices" ] ;
         fhir:text [ fhir:v "G碼" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "GA01[交通接送]: 每月4次，接送個案至醫院就診及復健。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "scCodeServices" ] ;
         fhir:text [ fhir:v "SC碼" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "SC01[喘息服務]: 每月2次，提供家屬喘息服務，每次4小時。"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "mealServices" ] ;
         fhir:text [ fhir:v "營養餐飲服務: 1日核定○○餐(午/晚餐)" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "1日核定2餐(午/晚餐)"
           ]
         ] )
       ] [
         fhir:linkId [ fhir:v "emergencyServices" ] ;
         fhir:text [ fhir:v "緊急救援服務" ] ;
         fhir:answer ( [
           fhir:value [
             a fhir:String ;
             fhir:v "緊急救援連線服務，24小時監控，遇緊急狀況立即通報。"
           ]
         ] )
       ] )
     ] [
       fhir:linkId [ fhir:v "otherServices" ] ;
       fhir:text [ fhir:v "轉介其他服務資源" ] ;
       fhir:answer ( [
         fhir:value [
           a fhir:String ;
           fhir:v "轉介至社區關懷據點，參與健康促進活動，維持社會參與。"
         ]
       ] )
     ] )
  ] [
     fhir:linkId [ fhir:v "otherNotes" ] ;
     fhir:text [ fhir:v "其他備註" ] ;
     fhir:answer ( [
       fhir:value [
         a fhir:String ;
         fhir:v "個案家屬配合度高，建議定期追蹤服務品質，如有需要可調整服務內容。"
       ]
     ] )
  ] ) . # 

