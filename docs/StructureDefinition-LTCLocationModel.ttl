       fhir:id [ fhir:v "LTCLocationModel.hierarchy.parentLocationReference" ] ;
       fhir:path [ fhir:v "LTCLocationModel.hierarchy.parentLocationReference" ] ;
       fhir:short [ fhir:v "上層位置參考" ] ;
       fhir:definition [ fhir:v "對上層位置資源的參考" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "string"^^xsd:anyURI ;
           fhir:l fhir:string
         ]
       ] ) ;
       fhir:mapping ( [
         fhir:identity [ fhir:v "LTCLocationModelToLTCLocation" ] ;
         fhir:map [ fhir:v "Location.partOf.reference" ]
       ] )
     ] )
  ] . # 

